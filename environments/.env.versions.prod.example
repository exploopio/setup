# =============================================================================
# Version Configuration - Production
# =============================================================================
# This file contains version tags and registry for Docker images.
# Copy to .env.versions.prod and update as needed.
#
# Usage: cp environments/.env.versions.prod.example .env.versions.prod
# =============================================================================

# Image registry (where to pull images from)
# Options:
#   ghcr.io/openctemio  - GitHub Container Registry (default, always available)
#   openctemio          - Docker Hub (requires images to be mirrored)
IMAGE_REGISTRY=ghcr.io/openctemio

# API version (from api repo)
API_VERSION=latest

# UI version (from ui repo)
UI_VERSION=latest

# Admin UI version (from admin-ui repo)
ADMIN_UI_VERSION=latest

# Migrations version (from api repo)
# Should match API_VERSION to ensure schema compatibility
MIGRATIONS_VERSION=latest

# Seed version (from api repo)
# Usually not needed in production, but available if needed
# SEED_VERSION=latest
