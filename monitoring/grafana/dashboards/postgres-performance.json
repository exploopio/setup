{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "expr": "pg_settings_max_connections",
          "legendFormat": "Max",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Transaction Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"openctem\"}[5m])",
          "legendFormat": "Commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"openctem\"}[5m])",
          "legendFormat": "Rollbacks/s",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{datname=\"openctem\"} / (pg_stat_database_blks_hit{datname=\"openctem\"} + pg_stat_database_blks_read{datname=\"openctem\"}) * 100",
          "legendFormat": "Hit %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Database Size",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"openctem\"}",
          "legendFormat": "Size",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Tuple Operations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_inserted{datname=\"openctem\"}[5m])",
          "legendFormat": "Inserts/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{datname=\"openctem\"}[5m])",
          "legendFormat": "Updates/s",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{datname=\"openctem\"}[5m])",
          "legendFormat": "Deletes/s",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Table Sizes (Top 10)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "topk(10, pg_stat_user_tables_size_bytes)",
          "legendFormat": "{{ relname }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Dead Tuples (Needs Vacuum)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "topk(10, pg_stat_user_tables_n_dead_tup)",
          "legendFormat": "{{ relname }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Locks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "pg_locks_count",
          "legendFormat": "{{ mode }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Replication Lag",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "pg_replication_lag",
          "legendFormat": "Lag",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["openctem", "postgres"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "OpenCTEM PostgreSQL Performance",
  "uid": "openctem-postgres-perf"
}
