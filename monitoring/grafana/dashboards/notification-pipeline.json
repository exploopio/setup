{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Notification Processing Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(openctem_notifications_processed_total[5m])",
          "legendFormat": "{{ status }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Outbox Queue Depth",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "openctem_notification_outbox_pending",
          "legendFormat": "Pending",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "title": "Failed Notifications",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "openctem_notification_outbox_failed",
          "legendFormat": "Failed",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Delivery Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(openctem_notification_delivery_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "P50 {{ provider }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(openctem_notification_delivery_duration_seconds_bucket[5m])) by (le, provider))",
          "legendFormat": "P99 {{ provider }}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Notifications by Provider",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(openctem_notifications_processed_total[1h])) by (provider)",
          "legendFormat": "{{ provider }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Pipeline Jobs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(platform_jobs_submitted_total[5m])) by (status)",
          "legendFormat": "{{ status }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Job Validation Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(job_validation_failures_total[5m])) by (reason)",
          "legendFormat": "{{ reason }}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["openctem", "notifications"],
  "time": { "from": "now-6h", "to": "now" },
  "title": "OpenCTEM Notification Pipeline",
  "uid": "openctem-notification-pipeline"
}
